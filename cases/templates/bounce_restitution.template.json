{
  "schema_version": "harness_case_template_v1",
  "template_id": "bounce_restitution",
  "capability_id": "bounce_restitution_ball",
  "description": "Runnable template for restitution-controlled rigid-body rebound after ground contact.",
  "fallback_supported": true,
  "parameter_ranges": {
    "drop_height_m": {"type": "float", "min": 0.8, "max": 2.2},
    "restitution": {"type": "float", "min": 0.25, "max": 0.9},
    "ball_mass_kg": {"type": "float", "min": 0.15, "max": 2.0},
    "gravity_m_s2": {"type": "float", "min": 9.81, "max": 9.81}
  },
  "object_count_ranges": {
    "bouncing_body": {"min": 1, "max": 1},
    "support": {"min": 1, "max": 1}
  },
  "physics_critical_assets": ["bouncing rigid body", "support collider", "restitution physics material"],
  "visual_only_assets": ["height guide material"],
  "camera_policy": {"default": "side_static", "allowed": ["side_static", "tracking_subject", "front_static"]},
  "perturbation_policy": {"positive_ratio": 0.7, "vary": ["drop_height_m", "restitution", "ball_mass_kg"], "lock": ["seed", "gravity_m_s2"]},
  "expected_invariants": [
    "descends_before_contact",
    "impact_contact_required",
    "rebound_after_contact",
    "restitution_bounded_rebound_height"
  ],
  "negative_modes": ["no_rebound", "energy_gain", "missing_contact"],
  "seed_policy": {"deterministic": true, "record_parameter_sample": true},
  "expected_artifact_contract": ["trajectory", "contact_events", "gravity_label", "material_restitution_label"]
}
