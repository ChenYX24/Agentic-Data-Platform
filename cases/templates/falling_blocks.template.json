{
  "schema_version": "harness_case_template_v1",
  "template_id": "falling_blocks",
  "capability_id": "rigid_body_gravity_collision",
  "description": "Parameterized gravity/contact case for falling rigid blocks.",
  "fallback_supported": true,
  "parameter_ranges": {
    "block_count": {"type": "int", "min": 1, "max": 3},
    "drop_height_m": {"type": "float", "min": 0.8, "max": 2.2},
    "gravity_m_s2": {"type": "float", "min": 8.0, "max": 12.0},
    "block_mass_kg": {"type": "float", "min": 0.5, "max": 3.0}
  },
  "object_count_ranges": {
    "falling_body": {"min": 1, "max": 3},
    "support": {"min": 1, "max": 1}
  },
  "physics_critical_assets": ["box rigid body", "floor collider"],
  "visual_only_assets": ["box material", "floor material"],
  "camera_policy": {
    "default": "side_static",
    "allowed": ["side_static", "top_down_fixed", "event_closeup"]
  },
  "perturbation_policy": {
    "positive_ratio": 0.75,
    "vary": ["block_count", "drop_height_m", "gravity_m_s2"],
    "lock": ["z_up_coordinate_system", "seed"]
  },
  "expected_invariants": [
    "falling_object_descends_under_gravity",
    "support_contact_exists",
    "no_floor_penetration"
  ],
  "negative_modes": ["floating_block", "missing_contact"],
  "seed_policy": {"deterministic": true, "record_parameter_sample": true}
}
