{
  "schema_version": "harness_case_template_v1",
  "template_id": "wind_balloon_drift",
  "capability_id": "force_field_wind_drift",
  "fallback_supported": true,
  "parameter_ranges": {
    "wind_speed_m_s": {"type": "float", "min": 0.8, "max": 4.0},
    "wind_angle_deg": {"type": "float", "min": -45.0, "max": 45.0},
    "body_mass_kg": {"type": "float", "min": 0.02, "max": 0.3},
    "buoyancy_scale": {"type": "float", "min": 0.8, "max": 1.35}
  },
  "object_count_ranges": {
    "wind_subject": {"min": 1, "max": 1},
    "support": {"min": 0, "max": 1}
  },
  "physics_critical_assets": [
    "wind_drift_body",
    "force_field"
  ],
  "visual_only_assets": [
    "skybox",
    "wind_direction_indicator"
  ],
  "camera_policy": {
    "default": "side_static",
    "allowed": ["side_static", "top_down", "tracking_subject"]
  },
  "perturbation_policy": {
    "positive_ratio": 0.7,
    "negative_modes": ["no_wind_drift", "wrong_direction", "missing_wind_label"]
  },
  "expected_invariants": [
    "wind vector is explicit and non-zero",
    "horizontal drift aligns with wind direction",
    "drift distance is bounded by expected range",
    "altitude stays inside envelope"
  ],
  "negative_modes": [
    "no_wind_drift",
    "wrong_direction",
    "missing_wind_label"
  ],
  "seed_policy": {
    "deterministic": true,
    "sample_parameters_from_seed": true
  }
}
