{
  "schema_version": "harness_case_template_v1",
  "template_id": "elastic_energy_launch",
  "capability_id": "elastic_energy_launch",
  "description": "Parameterized template for elastic stored-energy release into rigid-body launch motion. Spring launcher is the smoke family for generic elastic-energy launch.",
  "fallback_supported": true,
  "parameter_ranges": {
    "spring_constant_n_m": {"type": "float", "min": 60.0, "max": 220.0},
    "compression_m": {"type": "float", "min": 0.08, "max": 0.28},
    "payload_mass_kg": {"type": "float", "min": 0.25, "max": 1.2},
    "launch_angle_deg": {"type": "float", "min": 35.0, "max": 85.0}
  },
  "object_count_ranges": {
    "elastic_launcher": {"min": 1, "max": 1},
    "launched_body": {"min": 1, "max": 1},
    "support": {"min": 1, "max": 1}
  },
  "physics_critical_assets": ["elastic launcher", "launched rigid body", "collider", "support surface"],
  "visual_only_assets": ["spring coil visual", "trajectory guide overlay"],
  "camera_policy": {"default": "side_static", "allowed": ["side_static", "front_static", "tracking_subject", "event_closeup"]},
  "perturbation_policy": {"positive_ratio": 0.7, "vary": ["spring_constant_n_m", "compression_m", "payload_mass_kg", "launch_angle_deg"], "lock": ["seed"]},
  "expected_invariants": [
    "launched_body_starts_still",
    "release_event_exists",
    "post_release_speed_matches_energy_envelope",
    "height_gain_and_forward_displacement_are_positive",
    "energy_gain_stays_bounded"
  ],
  "negative_modes": ["missing_release_event", "no_launch_response", "energy_gain"],
  "seed_policy": {"deterministic": true, "record_parameter_sample": true},
  "expected_artifact_contract": ["trajectory", "spring_events", "energy_labels"]
}
